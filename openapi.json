{
  "openapi": "3.0.0",
  "info": {
    "title": "API de Productos",
    "version": "1.0.0",
    "description": "API REST para gestionar productos en el inventario."
  },
  "servers": [
    {
      "url": "http://localhost:8888/api",
      "description": "Servidor local"
    },
    {
      "url": "https://aoi2-w2.onrender.com/api",
      "description": "Servidor desplegado"
    }
  ],
  "paths": {
    "/auth/signin": {
      "post": {
        "summary": "Autenticar usuario",
        "tags": [
          "Autenticación"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "existente@usuario.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "micontraseña"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login exitoso",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string",
                  "example": "token=abc123; Path=/; HttpOnly"
                },
                "description": "Cookie con JWT token"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": "true"
                    },
                    "userId": {
                      "type": "string",
                      "example": "67t953m62b66c0f5d73be74d"
                    },
                    "email": {
                      "type": "string",
                      "example": "existente@usuario.com"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": false },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Datos inválidos"]
                    }
                  }
                },
                "example": {
                  "success": false,
                  "errors": ["Datos inválidos"]
                }
              }
            }
          },
          "400": {
            "description": "Solicitud incorrecta",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": false },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Debe ser un email válido"]
                    }
                  }
                },
                "examples": {
                  "EmailInvalido": {
                    "summary": "Email inválido",
                    "value": {
                      "success": false,
                      "errors": ["Debe ser un email válido"]
                    }
                  },
                  "PasswordFaltante": {
                    "summary": "Password faltante",
                    "value": {
                      "success": false,
                      "errors": ["El campo password es obligatorio"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/signup": {
      "post": {
        "summary": "Registrar nuevo usuario",
        "tags": [
          "Autenticación"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "nuevo@usuario.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "example": "ContraseñaSegura123"
                  },
                  "confirmPassword": {
                    "type": "string",
                    "example": "ContraseñaSegura123"
                  },
                  "verificationCode": {
                    "type": "string",
                    "length": 6,
                    "example": "123456"
                  }
                },
                "required": [
                  "email",
                  "password",
                  "confirmPassword",
                  "verificationCode"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario registrado exitosamente",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string",
                  "example": "token=abc123; Path=/; HttpOnly; SameSite=Lax"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "userId": {
                      "type": "string",
                      "example": "507f1f77bcf86cd799439011"
                    },
                    "email": {
                      "type": "string",
                      "example": "nuevo@usuario.com"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error en la solicitud",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "success": { "type": "boolean", "example": false },
                        "error": {
                          "type": "string",
                          "enum": [
                            "Contraseña no válida, debe tener al menos 8 caracteres y 1 número",
                            "Las contraseñas no coinciden",
                            "Código inválido o expirado",
                            "El usuario ya existe"
                          ]
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "UsuarioYaExiste": {
                    "summary": "El usuario ya existe",
                    "value": {
                      "success": false,
                      "errors": ["El usuario ya existe"]
                    }
                  },
                  "CodigoInvalidoOExpirado": {
                    "summary": "Código inválido o expirado",
                    "value": {
                      "success": false,
                      "errors": ["Código inválido o expirado"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/send-code": {
      "post": {
        "summary": "Enviar código de verificación",
        "tags": [
          "Autenticación"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "usuario@ejemplo.com"
                  }
                },
                "required": [
                  "email"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Código enviado exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Código enviado con éxito" },
                    "cooldown": { "type": "integer", "example": 60 },
                    "nextRequest": { "type": "string", "format": "date-time", "example": "2025-05-26T17:40:39.618Z" }
                  }
                },
                "example": {
                  "success": true,
                  "message": "Código enviado con éxito",
                  "cooldown": 60,
                  "nextRequest": "2025-05-26T17:40:39.618Z"
                }
              }
            }
          },
          "400": {
            "description": "Solicitud incorrecta",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": false },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Debe proporcionar un email válido"]
                    }
                  }
                },
                "examples": {
                  "EmailInvalido": {
                    "summary": "Email inválido",
                    "value": {
                      "success": false,
                      "errors": ["Debe proporcionar un email válido"]
                    }
                  },
                  "EspereParaReenviar": {
                    "summary": "Espere para reenviar",
                    "value": {
                      "success": false,
                      "errors": ["Espere xx segundos para reenviar el código"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Cerrar sesión de usuario",
        "tags": [
          "Autenticación"
        ],
        "description": "Elimina la cookie de autenticación JWT y cierra la sesión del usuario.",
        "responses": {
          "200": {
            "description": "Sesión cerrada correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Sesión cerrada correctamente" }
                  }
                },
                "example": {
                  "success": true,
                  "message": "Sesión cerrada correctamente"
                }
              }
            }
          }
        }
      }
    },
    "/products": {
      "get": {
        "summary": "Obtener todos los productos",
        "tags": [
          "Productos"
        ],
        "responses": {
          "200": {
            "description": "Listado de productos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "OK"
                    },
                    "products": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Product"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "500": {
            "description": "Error interno del servidor",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Error al obtener productos"]
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "summary": "Crear un nuevo producto",
        "tags": [
          "Productos"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Producto creado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "OK"
                    },
                    "message": {
                      "type": "string",
                      "example": "Producto creado exitosamente"
                    },
                    "product": {
                      "$ref": "#/components/schemas/Product"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "500": {
            "description": "Error interno del servidor",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Error al crear el producto"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "summary": "Obtener un producto por ID",
        "tags": [
          "Productos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID del producto a obtener"
          }
        ],
        "responses": {
          "200": {
            "description": "Producto encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "OK"
                    },
                    "product": {
                      "$ref": "#/components/schemas/Product"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "description": "Producto no encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Producto no encontrado"]
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Error al obtener el producto"]
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "summary": "Actualizar un producto existente",
        "tags": [
          "Productos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Producto actualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "description": "Producto no encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Producto no encontrado"]
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Error al actualizar el producto"]
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "summary": "Eliminar un producto",
        "tags": [
          "Productos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Producto eliminado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "OK"
                    },
                    "message": {
                      "type": "string",
                      "example": "Producto eliminado exitosamente"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "description": "Producto no encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Producto no encontrado"]
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Error al eliminar el producto"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/upload": {
      "post": {
        "summary": "Subir imagen al servidor",
        "tags": [
          "Archivos"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Archivo de imagen (JPEG, PNG, GIF)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Imagen subida exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "filename": {
                      "type": "string",
                      "example": "123456789-hola.jpg"
                    },
                    "path": {
                      "type": "string",
                      "example": "/images/123456789-hola.jpg"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Solicitud incorrecta",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "success": { "type": "boolean", "example": false },
                        "errors": {
                          "type": "array",
                          "items": { "type": "string" }
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "ArchivoNoProporcionado": {
                    "summary": "No se proporcionó ningún archivo",
                    "value": {
                      "success": false,
                      "errors": ["No se proporcionó ningún archivo"]
                    }
                  },
                  "ArchivoNoPermitido": {
                    "summary": "Solo se permiten imágenes (JPEG, PNG, GIF)",
                    "value": {
                      "success": false,
                      "errors": ["Solo se permiten imágenes (JPEG, PNG, GIF)"]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "413": {
            "description": "Archivo demasiado grande",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "El archivo excede el límite de 5MB"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token",
        "description": "Autenticación mediante cookies JWT"
      }
    },
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "67b67e8d556235d2d03cd524"
          },
          "nombre": {
            "type": "string",
            "example": "Reloj Inteligente"
          },
          "descripcion": {
            "type": "string",
            "example": "Reloj con inteligencia artificial."
          },
          "precio": {
            "type": "number",
            "example": 1460000
          },
          "marca": {
            "type": "string",
            "example": "Xiaomi"
          },
          "stock": {
            "type": "number",
            "example": 55
          },
          "img": {
            "type": "string",
            "example": ""
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-02-20T00:59:57.417Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-03-24T15:10:03.293Z"
          }
        }
      },
      "ProductInput": {
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string",
            "example": "Peluche"
          },
          "descripcion": {
            "type": "string",
            "example": "Peluche de osito."
          },
          "precio": {
            "type": "number",
            "example": 12000
          },
          "marca": {
            "type": "string",
            "example": "Detoys"
          },
          "stock": {
            "type": "number",
            "example": 500
          }
        },
        "required": [
          "nombre",
          "descripcion",
          "precio",
          "marca",
          "stock"
        ]
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Token inválido o expirado",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "success": {
                  "type": "boolean",
                  "example": false
                },
                "errors": {
                  "type": "array",
                  "items": { "type": "string" },
                  "example": ["Acceso no autorizado"]
                }
              }
            }
          }
        },
        "ForbiddenError": {
          "description": "No tienes permisos para esta acción",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "example": "error"
                  },
                  "message": {
                    "type": "string",
                    "example": "Acceso prohibido"
                  }
                }
              }
            }
          }
        },
        "BadRequestError": {
          "description": "Solicitud incorrecta",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "example": "error"
                  },
                  "message": {
                    "type": "string",
                    "example": "Datos inválidos"
                  }
                }
              }
            }
          }
        },
        "InternalServerError": {
          "description": "Error interno del servidor",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "success": {
                    "type": "boolean",
                    "example": false
                  },
                  "errors": {
                    "type": "array",
                    "items": { "type": "string" },
                    "example": ["Error interno del servidor"]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}