<%- include("template/header", {tituloWeb: 'Productos' }) %>
<body style="background-color: black;">

    <video src="/video/background.mp4" autoplay loop playsinline muted
        style="object-fit: cover; width: 100vw; height:100vh; position: fixed; left: 0;">
    </video>
    <div class="container " style="position: relative; height: 150px; margin-top: 3%;">
        <h1 class="display-2" style="color: white;">CRUD Productos</h1>
        <br>

        <a type="button" class="btn btn-success btn-lg w-100" href="/product/create" role="button">
            Agregar Producto
        </a>
        <br>
        <br>

        <div class="table-responsive-stack">
        <table class="table table-hover">
            <thead class="thead-dark">
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Nombre</th>
                    <th scope="col">Descripción</th>
                    <th scope="col">Precio</th>
                    <th scope="col">Marca</th>
                    <th scope="col">Stock</th>
                    <th scope="col">Detalle</th>
                </tr>
            </thead>

            <tbody id="products-table-body">
            </tbody>
        </table>
        </div>
        <br>

    </div>
    <script src="/js/products.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
        crossorigin="anonymous"></script>

    
</body>
</html>