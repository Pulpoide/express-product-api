<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/vnd.microsoft.icon" href="/favicon.ico" />
  <link rel="stylesheet" href="/css/styles.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
  <title>Product Manager App | <%= tituloWeb %>
  </title>
  <meta name="base-url" content="<%= baseUrl %>">
</head>

<body>
  <header class="p-3 text-bg-dark">
    <div class="container">
      <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
        <ul class="nav col-12 col-lg-auto me-lg-auto mb-2 justify-content-center mb-md-0">
          <li><a href="/" class="nav-link px-2 text-secondary text-white">Home</a></li>
          <li><a href="/products" class="nav-link px-2 text-white">Productos</a></li>
          <li><a href="/api-docs" class="nav-link px-2 text-white">Documentación</a></li>
        </ul>
        <div class="text-end d-flex align-items-center">
          <% if (typeof user !== 'undefined' && user) { %>
            <form id="logoutForm" method="POST" class="d-inline">
              <button type="button" class="btn btn-outline-danger me-2" id="logoutBtn">Logout</button>
            </form>
          <% } else { %>
            <a href="/signin" class="btn btn-outline-success me-2 text-white">Sign in</a>
            <a href="/signup" class="btn btn-success">Sign up</a>
          <% } %>
        </div>
      </div>
    </div>
  </header>
  <script src="/js/logout.js"></script>
</body>
</html>
