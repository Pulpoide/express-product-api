<%- include("template/header", { tituloWeb: 'Reset Password' }) %>

<body>
  <div class="container" style="margin-top: 50px;">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <h2 class="text-center">Reset Password</h2>

        <div id="errorMessage" class="alert alert-danger text-center" style="display: none;"></div>
        <div id="successMessage" class="alert alert-success text-center" style="display: none;"></div>

        <form id="resetPasswordForm" action="/auth/reset-password" method="POST">
          <input type="hidden" id="token" name="token" value="<%= token %>">
          <div class="mb-3">
            <label for="password" class="form-label">Nueva contraseña</label>
            <input type="password" class="form-control" id="password" name="password" required>
          </div>
          <div class="mb-3">
            <label for="confirmPassword" class="form-label">Confirmar contraseña</label>
            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
          </div>
          <div class="text-center">
            <button type="submit" class="btn btn-success">Restablecer contraseña</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="/js/resetPassword.js"></script>
</body>
</html>