<%- include("template/header", {tituloWeb: 'Producto' }) %>

  <body>
    <br>
    <div class="container">
      <h1 class="display-2">Detalle Producto</h1>

      <br>
      <table class="table table-hover">
        <thead>
          <tr>
            <th scope="col">#</th>
            <th scope="col">Nombre</th>
            <th scope="col">Descripción</th>
            <th scope="col">Precio</th>
            <th scope="col">Marca</th>
            <th scope="col">Stock</th>
            <th scope="col">Acciones</th>
          </tr>
        </thead>

        <tbody>

          <% if (product) { %>
            <tr>
              <th scope="row">
                <%= product._id %>
              </th>
              <td>
                <%= product.nombre %>
              </td>
              <td>
                <%= product.descripcion %>
              </td>
              <td>$<%= product.precio %>
              </td>
              <td>
                <%= product.marca %>
              </td>
              <td>
                <%= product.stock %>
              </td>
              <td>
                <a href="/product/edit/<%= product._id %>" class="btn btn-warning btn-sm">
                  Editar
                </a>
                <a id="btnEliminar" role="button" href="/products" class="btn btn-danger btn-sm"
                  data-code="<%=product._id%>">
                  Eliminar
                </a>
              </td>
            </tr>
            <% } %>


        </tbody>
      </table>
      <br>
      <h3>Imagen:</h3>
      <br>
      <div class="d-flex align-items-center justify-content-center w-100">
        <% if (product) { %>
          <div class="image-container">
            <img src="<%= product.img ? '/images/' + product.img : '/images/default.jpg' %>" class="img-thumbnail h-50"
              id="productImage" alt="Imagen del producto" />
          </div>
          <% } else { %>
            <p>Producto no encontrado.</p>
            <% } %>
      </div>
      <br>
      <br>

      <a href="/products"><button class="btn btn-dark w-100 btn-lg">Volver</button></a>
      <br>
      <br>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"></script>

  </body>

  </html>



  <script src="/js/detalle.js"></script>