<%- include("template/header", { tituloWeb: 'Forgot Password' }) %>

<body>
  <div class="container" style="margin-top: 50px;">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <h2 class="text-center">Restablecer Contraseña</h2>

        <div id="errorMessage" class="alert alert-danger text-center" style="display: none;"></div>
        <div id="successMessage" class="alert alert-success text-center" style="display: none;"></div>

        <form id="forgotPasswordForm" action="/auth/forgot-password" method="POST">
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" class="form-control" id="email" name="email" required>
          </div>
          <div class="text-center">
            <button type="submit" class="btn btn-success">Reset Password</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="/js/forgotPassword.js"></script>
</body>
</html>